# ── Core API ─────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── Database ─────────────────────────────────────────────────────────────────
# Local:      sqlite+aiosqlite:///./researchmind.db
# Render:     sqlite+aiosqlite:////data/researchmind.db   (persistent disk)
DATABASE_URL=sqlite+aiosqlite:///./researchmind.db

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=ResearchMind AI
APP_ENV=production

# ── CORS ─────────────────────────────────────────────────────────────────────
# Set to your Vercel deployment URL (no trailing slash)
FRONTEND_URL=https://your-project.vercel.app
# Comma-separated list of any additional allowed origins
ALLOWED_ORIGINS=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=researchmind-super-secret-key-change-in-production-2026
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
